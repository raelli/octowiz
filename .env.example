# Optional if LITELLM_BASE_URL and LITELLM_API_KEY are already set in ~/.claude/settings.json
LITELLM_BASE_URL=https://your-proxy.example.com
LITELLM_API_KEY=sk-your-key

# Required when AELLI_LITELLM_BASE is set — used as the Bearer token for A2A calls
# through the LiteLLM gateway. Without this, all hook events will get 401 Unauthorized.
AELLI_AUTH_TOKEN=sk-your-litellm-key
